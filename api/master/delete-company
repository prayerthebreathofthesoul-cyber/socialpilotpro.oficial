import type { VercelRequest, VercelResponse } from "@vercel/node";
import { requireMaster, supabaseAdmin } from "../_utils/masterAuth";

const OFFICIAL_EMAIL = "socialpilotpro.oficial@gmail.com";

function normalizeEmail(value: unknown) {
  return String(value || "").trim().toLowerCase();
}

export default async function handler(req: VercelRequest, res: VercelResponse) {
  if (req.method !== "POST") {
    return res.status(405).json({
      success: false,
      error: "Método não permitido. Use POST.",
    });
  }

  try {
    /**
     * 1. Segurança master
     * Só a conta oficial logada pode executar esta API.
     */
    const auth = await requireMaster(req);

    if (!auth.allowed) {
      return res.status(auth.status).json({
        success: false,
        error: auth.error,
      });
    }

    const { companyId, userId, email, isOfficial } = req.body;

    if (!companyId) {
      return res.status(400).json({
        success: false,
        error: "companyId é obrigatório.",
      });
    }

    /**
     * 2. Proteção extra contra exclusão da conta oficial
     */
    if (
      isOfficial === true ||
      normalizeEmail(email) === normalizeEmail(OFFICIAL_EMAIL)
    ) {
      return res.status(403).json({
        success: false,
        error: "A conta oficial não pode ser excluída.",
      });
    }

    /**
     * 3. Busca empresa no Supabase
     */
    const { data: company, error: companyError } = await supabaseAdmin
      .from("companies")
      .select("*")
      .eq("id", companyId)
      .single();

    if (companyError || !company) {
      return res.status(404).json({
        success: false,
        error: "Empresa não encontrada.",
        details: companyError?.message,
      });
    }

    /**
     * 4. Proteção baseada nos dados reais da empresa
     */
    if (
      company.is_official === true ||
      company.isMaster === true ||
      normalizeEmail(company.email) === normalizeEmail(OFFICIAL_EMAIL)
    ) {
      return res.status(403).json({
        success: false,
        error: "A conta oficial não pode ser excluída.",
      });
    }

    const authUserId =
      userId ||
      company.user_id ||
      company.userId ||
      company.auth_user_id ||
      company.authUserId ||
      null;

    /**
     * 5. Apagar dados relacionados à empresa.
     * 
     * Se uma tabela não existir, a API ignora o erro e continua.
     * Isso evita erro tipo: relation "posts" does not exist.
     */
    const relatedTables = [
      "posts",
      "media",
      "analytics",
      "plans",
      "integrations",
      "social_accounts",
      "scheduled_posts",
    ];

    for (const table of relatedTables) {
      const { error } = await supabaseAdmin
        .from(table)
        .delete()
        .eq("company_id", companyId);

      if (error) {
        console.warn(`Aviso ao limpar tabela ${table}:`, error.message);
      }
    }

    /**
     * 6. Apagar empresa
     */
    const { error: deleteCompanyError } = await supabaseAdmin
      .from("companies")
      .delete()
      .eq("id", companyId);

    if (deleteCompanyError) {
      return res.status(500).json({
        success: false,
        error: "Erro ao excluir empresa.",
        details: deleteCompanyError.message,
      });
    }

    /**
     * 7. Apagar usuário do Supabase Auth
     */
    if (authUserId) {
      const { error: deleteUserError } =
        await supabaseAdmin.auth.admin.deleteUser(authUserId);

      if (deleteUserError) {
        return res.status(500).json({
          success: false,
          error: "Empresa excluída, mas houve erro ao excluir usuário do Auth.",
          details: deleteUserError.message,
        });
      }
    }

    return res.status(200).json({
      success: true,
      message: "Empresa e usuário excluídos com sucesso.",
      deletedCompanyId: companyId,
      deletedUserId: authUserId,
    });
  } catch (error: any) {
    return res.status(500).json({
      success: false,
      error: "Erro interno ao excluir empresa.",
      details: error?.message || String(error),
    });
  }
}
